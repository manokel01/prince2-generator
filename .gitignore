# --- Virtual Environment & Python Garbage ---
.venv/
__pycache__/
*.py[cod]

# --- Secrets & Environment ---
.env

# --- Global Document Ignore ---
*.pdf
*.docx
*.doc
*.md

# --- Data Directory Logic ---
# 1. Ignore the entire data directory by default
data/

# 2. Allow the Golden Datasets (Master Spec & Mock Exams)
!data/golden_datasets/
!data/golden_datasets/*.md

# 3. Allow the Active Scenario Configuration
!data/target_scenario/
!data/target_scenario/active_scenario.md
!data/target_scenario/active_blacklist.json

# --- Allow root level documentation ---
!README.md
