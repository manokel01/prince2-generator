# --- Virtual Environment & Python Garbage ---
.venv/
__pycache__/
*.py[cod]

# --- Secrets & Environment ---
.env

# --- Global Document Ignore ---
# This ignores all raw study materials and generated exports locally.
*.pdf
*.docx
*.doc
*.md

# --- Data Directory Logic ---
# 1. Ignore all contents of the data directory recursively.
data/**/*

# 2. Allow the folders themselves so Git can traverse the structure.
!data/
!data/golden_datasets/
!data/target_scenario/

# 3. Allow only the non-proprietary architecture and audit files.
# NOTE: active_scenario.md is EXCLUDED here to prevent copyright issues.
!data/golden_datasets/*.md
!data/target_scenario/active_blacklist.json

# --- Allow root level documentation ---
!README.md

# --- Maintenance & Local Backups ---
# Keeps your v0.1 files local without cluttering the repository.
archive/
