# --- Virtual Environment & Python Garbage ---
.venv/
__pycache__/
*.py[cod]

# --- Secrets & Environment ---
.env

# --- Global Document Ignore ---
*.pdf
*.docx
*.doc
*.md

# --- Data Directory Logic ---
# 1. Ignore all contents of the data directory
data/**/*

# 2. Allow the folders themselves so Git can traverse them
!data/
!data/golden_datasets/
!data/target_scenario/

# 3. Allow specific critical configuration and spec files
!data/golden_datasets/*.md
!data/target_scenario/active_scenario.md
!data/target_scenario/active_blacklist.json

# --- Allow root level documentation ---
!README.md

# --- Maintenance & Local Backups ---
archive/
